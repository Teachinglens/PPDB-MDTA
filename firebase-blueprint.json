{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student application for MDTA ABU DZAR",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["Laki-laki", "Perempuan"] },
        "parentName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "registrationNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "birthDate", "gender", "parentName", "phoneNumber", "status"]
    },
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of student applications"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
