rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: students
    // Document ID: auto-generated or registration number
    // Fields:
    //   - fullName: string (required)
    //   - birthPlace: string
    //   - birthDate: string (required)
    //   - gender: string (required)
    //   - parentName: string (required)
    //   - phoneNumber: string (required)
    //   - address: string
    //   - status: string (required, 'pending', 'accepted', 'rejected')
    //   - registrationNumber: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "mahardikasandy1992@gmail.com" ||
         request.auth.token.email == "barlimahardikasandy@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStudent(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.birthDate is string &&
             data.gender in ['Laki-laki', 'Perempuan'] &&
             data.parentName is string && data.parentName.size() > 0 &&
             data.phoneNumber is string && data.phoneNumber.size() > 0 &&
             data.status in ['pending', 'accepted', 'rejected'];
    }

    // Rules for users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin();
    }

    // Rules for students collection
    match /students/{studentId} {
      // Public can create applications (pendaftaran)
      allow create: if isValidStudent(request.resource.data); 
      
      // Allow reading by registration number (for progress check)
      // This is still relatively open but validated by the app logic
      allow read: if true; 
      
      // Only admin can update status or delete
      allow update: if isAdmin() && isValidStudent(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
